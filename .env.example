# Database Configuration
POSTGRES_DB=snmp_metrics
POSTGRES_USER=snmpuser
POSTGRES_PASSWORD=snmppass
POSTGRES_PORT=5432

# Backend Configuration
BACKEND_PORT=8000

# Frontend Configuration
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost

# Collection Settings
DEFAULT_COLLECTION_INTERVAL=60

# Manager Configuration
MANAGER_API_KEY=change-me-in-production

# JWT Authentication (required — startup fails without this)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_HOURS=8

# Prometheus exporter (backend GET /api/metrics/prometheus) — empty disables it.
# Set a dedicated token; Prometheus sends it as `Authorization: Bearer <token>`.
PROMETHEUS_SCRAPE_TOKEN=

# Metrics retention (manager) — polls/traps older than this are purged weekly.
METRICS_RETENTION_DAYS=90

# Observability (required when using docker-compose.observability.yml)
GF_SECURITY_ADMIN_PASSWORD=replace-with-secure-grafana-password

# SNMP Trap ingestion (agent) — opt-in
TRAP_ENABLED=false
TRAP_LISTEN_PORT=162
TRAP_COMMUNITY=public
